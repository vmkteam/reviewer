      <column name="issueStats" type="jsonb" nullable="false" default="&#39;{}&#39;"></column>
      <column name="trafficLight" type="varchar" length="32" nullable="false"></column>
      <column name="createdAt" type="timestamptz" nullable="false" default="now()"></column>
      <column name="summary" type="varchar" length="2048" nullable="false"></column>
      <column name="isAccepted" type="boolean" nullable="false" default="false"></column>
      <column name="statusId" type="integer" nullable="false"></column>
      <pk name="reviewFiles_pkey">
        <column name="reviewFileId"></column>
