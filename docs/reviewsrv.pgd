      </fk>
      <unique name="UNQ_projects_projectKey">
        <column name="projectKey"></column>
      </unique>
    </table>
    <table name="reviews">
      <column name="reviewId" type="integer" nullable="false">
        <identity generated="by-default"></identity>
      </column>
      <column name="projectId" type="integer" nullable="false"></column>
      <column name="title" type="varchar" length="255" nullable="false"></column>
      <column name="description" type="varchar" length="2048" nullable="false"></column>
      <column name="externalId" type="varchar" length="32" nullable="false"></column>
      <column name="trafficLight" type="varchar" length="32" nullable="false" default="&#39;none&#39;"></column>
      <column name="commitHash" type="varchar" length="40" nullable="false"></column>
      <column name="sourceBranch" type="varchar" length="255" nullable="false"></column>
      <column name="targetBranch" type="varchar" length="255" nullable="false"></column>
      <column name="author" type="varchar" length="255" nullable="false"></column>
      <column name="createdAt" type="timestamptz" nullable="false" default="now()"></column>
      <column name="durationMS" type="integer" nullable="false" default="0"></column>
      <column name="modelInfo" type="jsonb" nullable="false" default="&#39;{}&#39;"></column>
      <column name="statusId" type="integer" nullable="false"></column>
      <column name="promptId" type="integer" nullable="false"></column>
      <column name="effortMinutes" type="integer"></column>
      <column name="aiSlopScore" type="real"></column>
      <pk name="reviews_pkey">
        <column name="reviewId"></column>
      </pk>
      <fk name="Ref_reviews_to_projects" to-table="projects" on-delete="RESTRICT" on-update="RESTRICT">
