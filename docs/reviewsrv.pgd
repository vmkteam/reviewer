      <fk name="Ref_issues_to_reviews" to-table="reviews" on-delete="RESTRICT" on-update="RESTRICT">
        <column name="reviewId" references="reviewId"></column>
      </fk>
    </table>
    <table name="users">
      <column name="userId" type="integer" nullable="false">
