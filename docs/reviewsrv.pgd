      <column name="title" type="varchar" length="255" nullable="false"></column>
      <column name="severity" type="varchar" length="16" nullable="false"></column>
      <column name="description" type="text" nullable="false"></column>
      <column name="content" type="text" nullable="false"></column>
      <column name="file" type="varchar" length="255" nullable="false"></column>
      <column name="lines" type="varchar" length="255" nullable="false"></column>
      <column name="comment" type="varchar" length="255"></column>
      <column name="localId" type="varchar" length="16"></column>
      <column name="processedAt" type="timestamptz"></column>
      <column name="createdAt" type="timestamptz" nullable="false" default="now()"></column>
      <column name="userId" type="integer"></column>
      <column name="suggestedFix" type="text"></column>
      <column name="statusId" type="integer" nullable="false"></column>
      <pk name="issues_pkey">
        <column name="issueId"></column>
      </pk>
      <fk name="Ref_issues_to_reviewFiles" to-table="reviewFiles" on-delete="RESTRICT" on-update="RESTRICT">
