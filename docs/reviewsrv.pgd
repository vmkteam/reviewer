<?xml version="1.0" encoding="UTF-8"?>
<pgd version="1" pg-version="17" default-schema="public">
  <project name="reviewsrv">
    <settings>
      <naming convention="camelCase" tables="plural"></naming>
      <defaults nullable="true" on-delete="restrict" on-update="restrict"></defaults>
    </settings>
  </project>
  <roles></roles>
  <tablespaces></tablespaces>
  <extensions></extensions>
  <sequences></sequences>
  <schema name="public">
    <table name="prompts">
      <column name="promptId" type="integer" nullable="false">
        <identity generated="by-default"></identity>
      </column>
      <column name="title" type="varchar" length="255" nullable="false"></column>
      <column name="common" type="text" nullable="false"></column>
      <column name="architecture" type="text" nullable="false"></column>
      <column name="code" type="text" nullable="false"></column>
      <column name="security" type="text" nullable="false"></column>
      <column name="tests" type="text" nullable="false"></column>
      <column name="operability" type="text" nullable="false"></column>
      <column name="createdAt" type="timestamptz" nullable="false" default="now()"></column>
      <column name="statusId" type="integer" nullable="false"></column>
      <pk name="prompts_pkey">
        <column name="promptId"></column>
      </pk>
      <fk name="Ref_prompts_to_statuses" to-table="statuses" on-delete="RESTRICT" on-update="RESTRICT">
        <column name="statusId" references="statusId"></column>
      </fk>
    </table>
    <table name="statuses">
      <column name="statusId" type="integer" nullable="false"></column>
      <column name="title" type="varchar" length="255" nullable="false"></column>
      <column name="alias" type="varchar" length="64"></column>
      <pk name="statuses_pkey">
        <column name="statusId"></column>
      </pk>
    </table>
    <table name="taskTrackers">
      <column name="taskTrackerId" type="integer" nullable="false">
        <identity generated="by-default"></identity>
      </column>
      <column name="title" type="varchar" length="255" nullable="false"></column>
      <column name="url" type="varchar" length="255" nullable="false"></column>
      <column name="authToken" type="varchar" length="255"></column>
      <column name="fetchPrompt" type="text" nullable="false"></column>
      <column name="createdAt" type="timestamptz" nullable="false" default="now()"></column>
      <column name="statusId" type="integer" nullable="false"></column>
      <pk name="taskTrackers_pkey">
        <column name="taskTrackerId"></column>
      </pk>
      <fk name="Ref_taskTrackers_to_statuses" to-table="statuses" on-delete="RESTRICT" on-update="RESTRICT">
        <column name="statusId" references="statusId"></column>
      </fk>
    </table>
    <table name="slackChannels">
      <column name="slackChannelId" type="integer" nullable="false">
        <identity generated="by-default"></identity>
      </column>
      <column name="title" type="varchar" length="255" nullable="false"></column>
      <column name="channel" type="varchar" length="255" nullable="false"></column>
      <column name="webhookURL" type="varchar" length="1024" nullable="false"></column>
      <column name="statusId" type="integer" nullable="false"></column>
      <pk name="slackChannels_pkey">
        <column name="slackChannelId"></column>
      </pk>
      <fk name="Ref_slackChannels_to_statuses" to-table="statuses" on-delete="RESTRICT" on-update="RESTRICT">
        <column name="statusId" references="statusId"></column>
      </fk>
    </table>
    <table name="projects">
      <column name="projectId" type="integer" nullable="false">
        <identity generated="by-default"></identity>
      </column>
      <column name="title" type="varchar" length="255" nullable="false"></column>
      <column name="vcsURL" type="varchar" length="255" nullable="false"></column>
      <column name="language" type="varchar" length="32" nullable="false"></column>
      <column name="projectKey" type="uuid" nullable="false"></column>
      <column name="instructions" type="text"></column>
      <column name="promptId" type="integer" nullable="false"></column>
      <column name="taskTrackerId" type="integer"></column>
      <column name="slackChannelId" type="integer"></column>
      <column name="createdAt" type="timestamptz" nullable="false" default="now()"></column>
      <column name="statusId" type="integer" nullable="false"></column>
      <pk name="projects_pkey">
        <column name="projectId"></column>
      </pk>
      <fk name="Ref_projects_to_prompts" to-table="prompts" on-delete="RESTRICT" on-update="RESTRICT">
