<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{ .Title }}</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; max-width: 960px; margin: 0 auto; padding: 20px; color: #1a1a2e; background: #f8f9fa; }
  h1 { border-bottom: 2px solid #e9ecef; padding-bottom: 8px; }
  h2 { color: #495057; margin-top: 32px; }
  .traffic-light { display: inline-block; padding: 4px 12px; border-radius: 4px; font-weight: 600; }
  .tl-red { background: #fee2e2; color: #991b1b; }
  .tl-yellow { background: #fef3c7; color: #92400e; }
  .tl-green { background: #d1fae5; color: #065f46; }
  .section { background: #fff; border: 1px solid #e9ecef; border-radius: 8px; padding: 20px; margin: 16px 0; }
  .section-title { font-size: 18px; font-weight: 600; color: #212529; margin: 0 0 12px 0; text-transform: capitalize; }
  pre { background: #282a36; color: #f8f8f2; padding: 16px; border-radius: 6px; overflow-x: auto; }
  code { font-family: "JetBrains Mono", "Fira Code", monospace; font-size: 14px; }
  p code { background: #e9ecef; padding: 2px 6px; border-radius: 3px; color: #d63384; }
  table { border-collapse: collapse; width: 100%; margin: 12px 0; }
  th, td { border: 1px solid #dee2e6; padding: 8px 12px; text-align: left; }
  th { background: #f8f9fa; font-weight: 600; }
  blockquote { border-left: 4px solid #dee2e6; margin: 12px 0; padding: 8px 16px; color: #6c757d; }
  pre.mermaid { background: #fff; color: #1a1a2e; text-align: center; }
</style>
</head>
<body>
<h1>{{ .Title }}</h1>
{{ range .Sections }}
<div class="section">
  <div class="section-title">{{ .Type }}</div>
  {{ .Content }}
</div>
{{ end }}
<script src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js"></script>
<script>mermaid.initialize({startOnLoad: true, theme: 'default'});</script>
</body>
</html>
